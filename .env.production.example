# Copy this to .env on the server and fill in all values.
# Never commit .env to version control.

# Database (Infomaniak MariaDB)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DBNAME"

# NextAuth
NEXTAUTH_URL="https://app.löyly.com"
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"

# Session cookie shared across subdomains
COOKIE_DOMAIN=".buurtsaunaloyly.nl"
# Language preference cookie shared across subdomains (must match COOKIE_DOMAIN)
NEXT_PUBLIC_COOKIE_DOMAIN=".buurtsaunaloyly.nl"

# Public URLs
NEXT_PUBLIC_APP_URL="https://app.buurtsaunaloyly.nl"
NEXT_PUBLIC_LANDING_URL="https://buurtsaunaloyly.nl"

# Runtime
NODE_ENV="production"

# Superadmin seed (only needed when running db:seed)
SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD="change-me"
